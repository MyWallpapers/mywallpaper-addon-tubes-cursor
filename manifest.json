{
  "name": "Tubes Cursor",
  "version": "4.2.2",
  "entry": "index.js",
  "description": "Interactive 3D tubes that follow the cursor with colorful lights and glow effect",
  "author": "MyWallpaper Community",
  "license": "MIT",
  "categories": [
    "cursor",
    "3d",
    "interactive"
  ],
  "settings": {
    "tubesSection": {
      "type": "section",
      "content": {
        "label": "🎨 Tubes"
      }
    },
    "tubeCount": {
      "type": "range",
      "content": {
        "label": "Number of Tubes",
        "default": 16,
        "min": 1,
        "max": 32,
        "step": 1
      }
    },
    "tubeRadius": {
      "type": "range",
      "content": {
        "label": "Tube Thickness",
        "description": "Radius of all tubes",
        "default": 0.03,
        "min": 0.005,
        "max": 0.15,
        "step": 0.005
      }
    },
    "tubeLength": {
      "type": "range",
      "content": {
        "label": "Tube Length",
        "description": "Number of segments (longer = more trail)",
        "default": 64,
        "min": 1,
        "max": 256,
        "step": 1
      }
    },
    "materialSection": {
      "type": "section",
      "content": {
        "label": "✨ Material"
      }
    },
    "metalness": {
      "type": "range",
      "content": {
        "label": "Metalness",
        "default": 1,
        "min": 0,
        "max": 1,
        "step": 0.05
      }
    },
    "roughness": {
      "type": "range",
      "content": {
        "label": "Roughness",
        "default": 0.25,
        "min": 0,
        "max": 1,
        "step": 0.05
      }
    },
    "animationSection": {
      "type": "section",
      "content": {
        "label": "🌊 Animation"
      }
    },
    "smoothness": {
      "type": "range",
      "content": {
        "label": "Smoothness",
        "description": "How quickly tubes follow the cursor",
        "default": 0.85,
        "min": 0.05,
        "max": 1,
        "step": 0.05
      }
    },
    "noise": {
      "type": "range",
      "content": {
        "label": "Noise",
        "description": "Organic movement intensity",
        "default": 0.05,
        "min": 0,
        "max": 0.3,
        "step": 0.01
      }
    },
    "tubeColorsSection": {
      "type": "section",
      "content": {
        "label": "🎨 Tube Colors (Gradient)"
      }
    },
    "tubeColor1": {
      "type": "color",
      "content": {
        "label": "Color 1",
        "default": "#f967fb"
      }
    },
    "tubeColor2": {
      "type": "color",
      "content": {
        "label": "Color 2",
        "default": "#ff6b6b"
      }
    },
    "tubeColor3": {
      "type": "color",
      "content": {
        "label": "Color 3",
        "default": "#53bc28"
      }
    },
    "randomizeTubeColors": {
      "type": "button",
      "content": {
        "label": "Actions",
        "buttonLabel": "🎲 Randomize Tube Colors"
      }
    },
    "lightColorsSection": {
      "type": "section",
      "content": {
        "label": "💡 Lights"
      }
    },
    "lightIntensity": {
      "type": "range",
      "content": {
        "label": "Light Intensity",
        "default": 200,
        "min": 0,
        "max": 500,
        "step": 10
      }
    },
    "lightColor1": {
      "type": "color",
      "content": {
        "label": "Light 1 (Bottom-Left)",
        "default": "#83f36e"
      }
    },
    "lightColor2": {
      "type": "color",
      "content": {
        "label": "Light 2 (Top-Left)",
        "default": "#fe8a2e"
      }
    },
    "lightColor3": {
      "type": "color",
      "content": {
        "label": "Light 3 (Bottom-Right)",
        "default": "#ff008a"
      }
    },
    "lightColor4": {
      "type": "color",
      "content": {
        "label": "Light 4 (Top-Right)",
        "default": "#60aed5"
      }
    },
    "randomizeLightColors": {
      "type": "button",
      "content": {
        "label": "Actions",
        "buttonLabel": "🎲 Randomize Light Colors"
      }
    },
    "bloomSection": {
      "type": "section",
      "content": {
        "label": "🌟 Bloom Effect"
      }
    },
    "bloomEnabled": {
      "type": "boolean",
      "content": {
        "label": "Enable Bloom",
        "default": true
      }
    },
    "bloomThreshold": {
      "type": "range",
      "content": {
        "label": "Threshold",
        "default": 0,
        "min": 0,
        "max": 1,
        "step": 0.05
      }
    },
    "bloomStrength": {
      "type": "range",
      "content": {
        "label": "Strength",
        "default": 0.7,
        "min": 0,
        "max": 10,
        "step": 0.1
      }
    },
    "bloomRadius": {
      "type": "range",
      "content": {
        "label": "Radius",
        "default": 1.5,
        "min": 0,
        "max": 3,
        "step": 0.1
      }
    },
    "actionsSection": {
      "type": "section",
      "content": {
        "label": "⚡ Quick Actions"
      }
    },
    "randomizeAll": {
      "type": "button",
      "content": {
        "label": "Randomize",
        "buttonLabel": "🎲 Randomize All Colors"
      }
    }
  },
  "defaultLayout": {
    "xPercent": 0,
    "yPercent": 0,
    "widthPercent": 100,
    "heightPercent": 100
  },
  "ui": {
    "pointerEvents": "none"
  }
}
